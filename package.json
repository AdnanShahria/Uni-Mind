{
  "name": "unimind",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --raw \"npm run dev --workspace=frontend\" \"wrangler pages dev frontend/public --port 8788\"",
    "dev:full": "node dev-start.js",
    "dev:all": "node dev-start.js",
    "build": "npm run build --workspace=frontend",
    "deploy": "npm run build && wrangler pages deploy dist",
    "lint": "npm run lint --workspaces --if-present",
    "db:watch": "node watch-db.js",
    "db:turso": "node watch-db.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "concurrently": "^9.2.1",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
